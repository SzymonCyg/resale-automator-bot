{
  "manifest_version": 3,
  "name": "Vinted Manager Helper",
  "version": "0.5.6",
  "description": "Panel do zarządzania kontami Vinted: podgląd przedmiotów, ponowne wystawianie z edycją zdjęć i cen, auto-odpowiedzi.",
  "permissions": ["storage", "alarms", "activeTab", "tabs", "scripting"],
  "host_permissions": [
    "https://*.vinted.pl/*",
    "https://*.vinted.fr/*",
    "https://*.vinted.de/*",
    "https://*.vinted.es/*",
    "https://*.vinted.it/*",
    "https://*.vinted.nl/*",
    "https://*.vinted.cz/*",
    "https://*.vinted.sk/*",
    "https://*.vinted.co.uk/*",
    "https://*.vinted.net/*",
    "https://*.vinted.com/*",
    "https://*.lovable.app/*",
    "https://*.lovable.dev/*",
    "https://*.supabase.co/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://*.lovable.app/*",
      "https://*.lovable.dev/*",
      "http://localhost/*"
    ]
  },
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Vinted Manager" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "content_scripts": [
    {
      "matches": [
        "https://*.vinted.pl/*",
        "https://*.vinted.fr/*",
        "https://*.vinted.de/*",
        "https://*.vinted.es/*",
        "https://*.vinted.it/*",
        "https://*.vinted.nl/*",
        "https://*.vinted.cz/*",
        "https://*.vinted.sk/*",
        "https://*.vinted.co.uk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.css", "panel.js", "page-bridge.js"],
      "matches": [
        "https://*.vinted.pl/*", "https://*.vinted.fr/*", "https://*.vinted.de/*",
        "https://*.vinted.es/*", "https://*.vinted.it/*", "https://*.vinted.nl/*",
        "https://*.vinted.cz/*", "https://*.vinted.sk/*", "https://*.vinted.co.uk/*"
      ]
    }
  ]
}
